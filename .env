# ---------------------------------------------------------------------------
# INFLOR - Credenciais
# ---------------------------------------------------------------------------
LOGIN_INFLOR=lucas.castro@re.green
SENHA_INFLOR=d07d2822-d29

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
SECRET_NAME=inflor/credentials

# ---------------------------------------------------------------------------
# Lake S3 (re.green-assets — monitorado pelo NiFi)
# ---------------------------------------------------------------------------
# Ambiente: stg (testes) | prd (produção)
LAKE_ENV=prd
LAKE_S3_BUCKET=re.green-assets

# Modo teste local: True = extrai e salva local, NÃO sobe ao lake
# Use DRY_RUN=True para validar extração sem afetar o pipeline
DRY_RUN=False

# ---------------------------------------------------------------------------
# Debug (screenshots/html em falhas — bucket interno, não é o lake)
# ---------------------------------------------------------------------------
DEBUG_S3_BUCKET=datalake-inflor-raw

# ---------------------------------------------------------------------------
# Logs no CloudWatch (opcional) — preencher com nome do log group
# ---------------------------------------------------------------------------
CLOUDWATCH_LOG_GROUP=

# ---------------------------------------------------------------------------
# Saída local — deixar em branco para usar o padrão (C:\inflor-extrator\output\...)
# ---------------------------------------------------------------------------
SAIDA_LOCAL_APONTAMENTO=
SAIDA_LOCAL_MODELO=
